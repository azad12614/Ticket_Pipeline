    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
