  "description": "",
  "main": "index.ts",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "node --env-file=.env src/index.ts",
    "build": "tsc",
    "lint": "eslint .",
    "format": "prettier --write src",
    "migrate": "node --env-file=.env migrations/migrate.ts",
